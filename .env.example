# Variables de entorno requeridas por NewGame+Save.
# Copia este archivo como .env y rellena los valores reales.
#
# En producción (Railway / Fly.io / Render) NO uses este archivo —
# configura las variables en el dashboard de la plataforma.

# ── ITAD ──
# API key de IsThereAnyDeal — obtén una en https://isthereanydeal.com/apps/my/
ITAD_API_KEY=tu_clave_aqui

# ── Sentry (opcional, deja vacío en local si no quieres tracking) ──
# Crea proyectos en https://sentry.io → uno Python/Flask, otro Browser JavaScript
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
